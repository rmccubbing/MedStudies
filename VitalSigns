                    <th colSpan={2} className="border border-slate-700 bg-gray-50 text-center text-[10px] font-normal">Left Size</th>
                    {renderTextCols('lSize')}
                  </tr>
                  <tr>
                    <th colSpan={2} className="border border-slate-700 bg-gray-50 text-center text-[10px] font-normal">Left Reaction</th>
                    {renderTextCols('lRx')}
