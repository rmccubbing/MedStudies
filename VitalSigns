                      <div className="flex justify-between w-full max-w-[700px]">
                        <span>If ↓ = Clinical Review</span>
                        <span>S = Strong<br/>AF = Abnormal Flexion</span>
                        <span>M = Moderate<br/>AE = Abnormal Extension</span>
                        <span>W = Weak<br/>SP = Spontaneous</span>
                        <span>A = Absent<br/>Wd = Withdrawal</span>
