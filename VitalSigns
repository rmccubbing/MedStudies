                    {renderTextCols('ra')}
                  </tr>
                  <tr>
                    <th colSpan={2} className="border border-slate-700 bg-gray-50 text-center text-[10px] font-normal">Left Arm</th>
                    {renderTextCols('la')}
                  </tr>
                  <tr>
                    <th rowSpan={2} className="border border-slate-700 bg-gray-50 text-[10px]" style={{ writingMode: 'vertical-rl', transform: 'rotate(180deg)' }}>Leg</th>
